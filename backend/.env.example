# ============================================
# NODE ENVIRONMENT
# ============================================
# development | production | test
# Determines which environment your app runs in
# Different behaviors (logging, error handling, etc.) based on this value
# OPTIONAL (default set to development)
NODE_ENV=development

# ============================================
# SERVER PORT
# ============================================
# Port number where your backend server will run
# Default: 8000 if not specified
# Make sure this port is free and not used by other services
PORT=8000

# ============================================
# DATABASE CONNECTION
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# 
# For local development:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/mydb
#
# For production (Neon, Vercel Postgres, etc.):
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
#
# ⚠️ NEVER use same credentials for production and development
# ⚠️ Always enable SSL (sslmode=require) in production
DATABASE_URL=postgresql://postgres:test123@localhost:5432/mydb

# ============================================
# CORS ALLOWED ORIGINS
# ============================================
# Frontend URLs that are allowed to access your API
# 
# For multiple origins, separate with commas (NO spaces):
# FRONTEND_URL=http://localhost:3000,http://localhost:3001,https://myapp.com
#
# For production:
# FRONTEND_URL=https://your-app.vercel.app,https://yourdomain.com
#
# ⚠️ In production, NEVER use "*" (wildcard)
# ⚠️ Always include protocol (http:// or https://)
# ⚠️ NO trailing slash at the end
FRONTEND_URL=http://localhost:3000

# ============================================
# DEPLOYMENT REMINDERS (Vercel/Other Hosting)
# ============================================
# ☑️ Add ALL 3 variables (NODE_ENV, DATABASE_URL, FRONTEND_URL) to Vercel except (PORT)
# ☑️ Use production values in Vercel (different from local)
# ☑️ Restart server after changing any environment variable