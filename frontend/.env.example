# Backend API Configuration
# Required for production, optional for local development

# For local development (default: http://localhost:8000/api)
# Uncomment and set if your local backend runs on a different port/url which we set in backend config (docker)
# NEXT_PUBLIC_API_URL=http://localhost:8000/api

# For production (required)
# IMPORTANT: Always include /api at the end of the URL
# Example: https://api.yourdomain.com/api or https://yourdomain.com/api
# DO NOT include trailing slash 
# Example: https://api.yourdomain.com/api/
NEXT_PUBLIC_API_URL=""
